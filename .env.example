# Copy this file to `.env` for local development.
# Do not commit your real secrets.

# MongoDB connection used by submissions, pair results, and embedding cache
MONGODB_URI=mongodb://localhost:27017

# Comma-separated frontend origins allowed to call the FastAPI backend
CORS_ORIGINS=http://localhost:3000

# Optional: required only if you want IEEE Xplore as a corpus source
IEEE_XPLORE_API_KEY=
